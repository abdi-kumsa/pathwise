# ── Database ───────────────────────────────────────────────
DB_USER=pathwise_user
DB_PASSWORD=pathwise_pass
DB_NAME=pathwise_db
DB_HOST=db
DB_PORT=5432

# Full connection URL (constructed from the above in docker-compose)
DATABASE_URL=postgresql://pathwise_user:pathwise_pass@db:5432/pathwise_db

# ── Backend API ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8000
